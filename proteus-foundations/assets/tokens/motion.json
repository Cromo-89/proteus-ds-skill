{
  "$description": "Proteus motion — duration and easing primitives. Components compose these (e.g. a fade uses duration.fast + easing.standard). Mode-agnostic.",
  "duration": {
    "$type": "duration",
    "instant": { "$value": { "value": 50,  "unit": "ms" } },
    "fast":    { "$value": { "value": 120, "unit": "ms" } },
    "normal":  { "$value": { "value": 200, "unit": "ms" } },
    "slow":    { "$value": { "value": 320, "unit": "ms" } },
    "slower":  { "$value": { "value": 500, "unit": "ms" } }
  },
  "easing": {
    "$type": "cubicBezier",
    "standard":    { "$value": [0.2, 0, 0, 1],     "$description": "Default for most UI transitions." },
    "decelerate":  { "$value": [0.05, 0.7, 0.1, 1], "$description": "Entering elements — fast in, eases out." },
    "accelerate":  { "$value": [0.3, 0, 1, 1],     "$description": "Exiting elements — eases in, fast out." },
    "linear":      { "$value": [0, 0, 1, 1],       "$description": "Progress and continuous motion." }
  }
}
